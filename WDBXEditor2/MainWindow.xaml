<Window x:Class="WDBXEditor2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" Title="WDBXEditor2" Height="640" Width="960"
        MinWidth="960" MinHeight="640" Icon="/Assets/icon.ico">
    <Window.CommandBindings>
        <CommandBinding Command="Open" Executed="Open_Click"/>
        <CommandBinding Command="Save" Executed="Save_Click"/>
        <CommandBinding Command="SaveAs" Executed="SaveAs_Click"/>
        <CommandBinding Command="Close" Executed="Close_Click"/>
    </Window.CommandBindings>
    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="Open"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="Save"/>
        <KeyBinding Key="S" Modifiers="Ctrl+Shift" Command="SaveAs"/>
        <KeyBinding Key="W" Modifiers="Ctrl" Command="Close"/>
    </Window.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition />
            <RowDefinition Height="215" />
        </Grid.RowDefinitions>
        <Menu IsMainMenu="True" Grid.Row="0" Grid.ColumnSpan="2">
            <MenuItem Header="文件(_F)">
                <MenuItem x:Name="Open" Header="打开..." Click="Open_Click" InputGestureText="Ctrl+O"/>
                <Separator />
                <MenuItem x:Name="Save" Header="保存" Click="Save_Click" InputGestureText="Ctrl+S"/>
                <MenuItem x:Name="SaveAs" Header="另存为..." Click="SaveAs_Click" InputGestureText="Ctrl+Shift+S"/>
                <Separator />
                <MenuItem x:Name="CloseDB" Header="关闭 DB2" Click="Close_Click" InputGestureText="Ctrl+W"/>
                <MenuItem x:Name="Exit" Header="退出" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="编辑(_E)"/>
            <MenuItem Header="导出(_X)"/>
            <MenuItem Header="工具(_T)"/>
        </Menu>
        <Grid Grid.Row="1" Grid.ColumnSpan="2">
            <DataGrid x:Name="DB2DataGrid" Margin="5,5,5,5" Background="#FF939393" CanUserResizeRows="False"
                      CanUserReorderColumns="False" CanUserSortColumns="False" AutoGenerateColumns="True"
                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                      ItemsSource="{Binding null, IsAsync=True}" EnableColumnVirtualization="True" EnableRowVirtualization="True"
                      CellEditEnding="DB2DataGrid_CellEditEnding" />
        </Grid>
        <Grid Grid.Row="2" Grid.Column="0">
            <GroupBox Header="文件" Margin="5,0,5,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="350"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <ListBox x:Name="OpenDBItems" Margin="0,0,5,0" SelectionChanged="OpenDBItems_SelectionChanged" />
                    </Grid>
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition Height="20"/>
                        </Grid.RowDefinitions>
                        <GroupBox Grid.Row="0" Header="行" Margin="0,-10,0,5">
                            <Grid Margin="8,4,8,4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="PageInfoText" Grid.Row="0" Text="未加载 DB2" Margin="0,0,0,8"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal">
                                    <Button x:Name="PreviousPageButton" Content="上一页" Width="80" Height="24" Click="PreviousPage_Click" IsEnabled="False"/>
                                    <Button x:Name="NextPageButton" Content="下一页" Width="80" Height="24" Margin="8,0,0,0" Click="NextPage_Click" IsEnabled="False"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                        <ProgressBar x:Name="ProgressBar" Grid.Row="1" Value="0" />
                    </Grid>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>
